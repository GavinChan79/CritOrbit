// CritOrbit is configured for PostgreSQL-backed deployments.
// The relational model stays unchanged across local, preview, and production
// environments so Prisma migrations and seeded app flows remain consistent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum HelperType {
  INDIVIDUAL
  TEAM
}

enum HelperStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
}

enum HelperPriceTier {
  BUDGET
  STANDARD
  PREMIUM
}

enum HelperExperienceLevel {
  NO_EXPERIENCE
  LESS_THAN_1_YEAR
  ONE_TO_TWO_YEARS
  THREE_TO_FIVE_YEARS
  FIVE_PLUS_YEARS
  EXPERT_ADVANCED
}

enum HelperPriceAnchor {
  BELOW_RM100
  RM100
  RM200
  RM300
  RM400
  RM500
  RM700
  RM1000_PLUS
}

enum HelperCategory {
  INTERIOR_DESIGN
  ARCHITECTURE
  FINANCE
  BUSINESS
  ECONOMICS
  INVESTMENT
  CORPORATE_GOVERNANCE
  ETHICS
  MARKETING
}

enum HelperApplicationFileKind {
  PORTFOLIO
  IDENTITY_FRONT
  IDENTITY_BACK
}

enum HelperVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum LeadTaskType {
  RENDERING
  LAYOUT
  PORTFOLIO
  PRESENTATION_BOARD
  REPORT
  CASE_STUDY
  FINANCIAL_ANALYSIS
  CALCULATION_MODEL
  PRESENTATION_SLIDES
  ESSAY
  RESEARCH_ANALYSIS
  OTHERS
}

enum LeadUrgency {
  RELAXED
  NORMAL
  ASAP
}

enum LeadStatus {
  NEW
  CONTACTED
  ASSIGNED
  COMPLETED
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum LeadLifecycleStage {
  VISITOR
  LEAD
  CONTACTED
  ASSIGNED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STUDENT)
  createdAt    DateTime @default(now())
  leads        Lead[]
  leadDrafts   LeadDraft[]
}

model Helper {
  id               String         @id @default(cuid())
  name             String
  type             HelperType     @default(INDIVIDUAL)
  teamSize         Int?
  isVerified       Boolean        @default(false)
  projectsCompleted Int           @default(0)
  experienceLevel  HelperExperienceLevel @default(NO_EXPERIENCE)
  responseTime     String?
  deliveryTime     String?
  repeatClients    Int?
  priceTier        HelperPriceTier @default(STANDARD)
  priceAnchor      HelperPriceAnchor @default(RM100)
  impressionCount  Int            @default(0)
  clickCount       Int            @default(0)
  selectionCount   Int            @default(0)
  status           HelperStatus   @default(ACTIVE)
  category         HelperCategory
  specialties      Json
  shortBio         String
  portfolioNote    String?
  email            String?
  whatsappNumber   String?
  agreedToTerms    Boolean        @default(false)
  agreedAt         DateTime?
  displayOrder     Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  applicationFiles HelperApplicationFile[]
  verification     HelperVerification?
  portfolioItems   HelperPortfolioItem[]
  selectedForLeads Lead[]         @relation("SelectedHelper")
  assignedLeads    Lead[]         @relation("AssignedHelper")
}

model HelperApplicationFile {
  id         String                    @id @default(cuid())
  helperId    String
  kind       HelperApplicationFileKind
  fileName   String
  mimeType   String
  sizeBytes  Int
  content    Bytes
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  helper     Helper                    @relation(fields: [helperId], references: [id], onDelete: Cascade)

  @@index([helperId, kind, createdAt])
}

model HelperPortfolioItem {
  id          String   @id @default(cuid())
  helperId     String
  title       String
  imageUrl    String
  description String?
  externalLink String?
  sourceApplicationFileId String? @unique
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  helper      Helper   @relation(fields: [helperId], references: [id], onDelete: Cascade)

  @@index([helperId, displayOrder])
}

model HelperVerification {
  id               String                   @id @default(cuid())
  helperId         String                   @unique
  icFrontUrl       String
  icBackUrl        String
  icFrontFileName  String
  icBackFileName   String
  icFrontMimeType  String
  icBackMimeType   String
  icFrontContent   Bytes
  icBackContent    Bytes
  status           HelperVerificationStatus @default(PENDING)
  adminNote        String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  helper           Helper                   @relation(fields: [helperId], references: [id], onDelete: Cascade)
}

model Lead {
  id               String             @id @default(cuid())
  clientRequestKey String?            @unique
  userId           String?
  category         HelperCategory
  taskType         LeadTaskType
  urgency          LeadUrgency
  deadline         DateTime
  budget           Int?
  description      String
  selectedHelperId String?
  assignedHelperId String?
  leadScore        Int
  leadTemperature  LeadTemperature
  lifecycleStage   LeadLifecycleStage @default(LEAD)
  whatsappClicked  Boolean            @default(false)
  status           LeadStatus         @default(NEW)
  dealClosed       Boolean            @default(false)
  notes            String             @default("")
  dealValue        Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  selectedHelper   Helper?            @relation("SelectedHelper", fields: [selectedHelperId], references: [id], onDelete: SetNull)
  assignedHelper   Helper?            @relation("AssignedHelper", fields: [assignedHelperId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([category, taskType])
}

model LeadDraft {
  id          String         @id @default(cuid())
  userId      String?
  category    HelperCategory
  taskType    LeadTaskType
  urgency     LeadUrgency
  deadline    DateTime
  budget      Int?
  description String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
