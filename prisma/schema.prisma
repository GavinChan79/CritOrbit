// CritOrbit is configured for PostgreSQL-backed deployments.
// The relational model stays unchanged across local, preview, and production
// environments so Prisma migrations and seeded app flows remain consistent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum HelperType {
  INDIVIDUAL
  TEAM
}

enum HelperStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  FROZEN
  ARCHIVED
}

enum HelperPriceTier {
  BUDGET
  STANDARD
  PREMIUM
}

enum HelperExperienceLevel {
  NO_EXPERIENCE
  LESS_THAN_1_YEAR
  ONE_TO_TWO_YEARS
  THREE_TO_FIVE_YEARS
  FIVE_PLUS_YEARS
  EXPERT_ADVANCED
}

enum HelperPriceAnchor {
  BELOW_RM100
  RM100
  RM200
  RM300
  RM400
  RM500
  RM600
  RM700
  RM800
  RM900
  RM1000_PLUS
}

enum HelperTrustLevel {
  STANDARD_HELPER
  VERIFIED_HELPER
  TRUSTED_HELPER
}

enum HelperCategory {
  INTERIOR_DESIGN
  ARCHITECTURE
  FINANCE
  BUSINESS
  ECONOMICS
  INVESTMENT
  CORPORATE_GOVERNANCE
  ETHICS
  MARKETING
}

enum HelperApplicationFileKind {
  PORTFOLIO
  IDENTITY_FRONT
  IDENTITY_BACK
}

enum HelperVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum LeadTaskType {
  RENDERING
  LAYOUT
  PORTFOLIO
  PRESENTATION_BOARD
  REPORT
  CASE_STUDY
  FINANCIAL_ANALYSIS
  CALCULATION_MODEL
  PRESENTATION_SLIDES
  ESSAY
  RESEARCH_ANALYSIS
  OTHERS
}

enum LeadUrgency {
  RELAXED
  NORMAL
  ASAP
}

enum LeadStatus {
  NEW
  CONTACTED
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAYMENT_LINK_SENT
  PAID
  REFUNDED
  RELEASE_READY
  RELEASED
  PAYMENT_FAILED
  PAYMENT_EXPIRED
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum LeadLifecycleStage {
  VISITOR
  LEAD
  CONTACTED
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum LeadInviteGroup {
  PREFERRED
  BACKUP
}

enum LeadInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  UNAVAILABLE
}

enum LeadInviteDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STUDENT)
  createdAt    DateTime @default(now())
  leads        Lead[]
  leadDrafts   LeadDraft[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Helper {
  id               String         @id @default(cuid())
  name             String
  type             HelperType     @default(INDIVIDUAL)
  teamSize         Int?
  isVerified       Boolean        @default(false)
  trustLevel       HelperTrustLevel @default(STANDARD_HELPER)
  projectsCompleted Int           @default(0)
  experienceLevel  HelperExperienceLevel @default(NO_EXPERIENCE)
  responseTime     String?
  deliveryTime     String?
  repeatClients    Int?
  priceTier        HelperPriceTier @default(STANDARD)
  submittedPriceAnchor HelperPriceAnchor @default(RM100)
  priceAnchor      HelperPriceAnchor @default(RM100)
  priceLockedByAdmin Boolean      @default(false)
  impressionCount  Int            @default(0)
  clickCount       Int            @default(0)
  selectionCount   Int            @default(0)
  studentsHelpedCount Int         @default(0)
  lastBookedAt     DateTime?
  status           HelperStatus   @default(ACTIVE)
  category         HelperCategory
  specialties      Json
  shortBio         String
  portfolioNote    String?
  email            String?
  whatsappNumber   String?
  agreedToTerms    Boolean        @default(false)
  agreedAt         DateTime?
  displayOrder     Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  applicationFiles HelperApplicationFile[]
  verification     HelperVerification?
  portfolioItems   HelperPortfolioItem[]
  selectedForLeads Lead[]         @relation("SelectedHelper")
  assignedLeads    Lead[]         @relation("AssignedHelper")
  leadInvites      LeadInvite[]
}

model HelperApplicationFile {
  id         String                    @id @default(cuid())
  helperId    String
  kind       HelperApplicationFileKind
  fileName   String
  mimeType   String
  sizeBytes  Int
  content    Bytes
  blobUrl    String?
  blobPathname String?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  helper     Helper                    @relation(fields: [helperId], references: [id], onDelete: Cascade)

  @@index([helperId, kind, createdAt])
}

model HelperPortfolioItem {
  id          String   @id @default(cuid())
  helperId     String
  title       String
  imageUrl    String
  description String?
  externalLink String?
  sourceApplicationFileId String? @unique
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  helper      Helper   @relation(fields: [helperId], references: [id], onDelete: Cascade)

  @@index([helperId, displayOrder])
}

model HelperVerification {
  id               String                   @id @default(cuid())
  helperId         String                   @unique
  icFrontUrl       String
  icBackUrl        String
  icFrontFileName  String
  icBackFileName   String
  icFrontMimeType  String
  icBackMimeType   String
  icFrontContent   Bytes
  icBackContent    Bytes
  status           HelperVerificationStatus @default(PENDING)
  adminNote        String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  helper           Helper                   @relation(fields: [helperId], references: [id], onDelete: Cascade)
}

model Lead {
  id               String             @id @default(cuid())
  clientRequestKey String?            @unique
  userId           String?
  category         HelperCategory
  taskType         LeadTaskType
  urgency          LeadUrgency
  deadline         DateTime
  budget           Int?
  description      String
  selectedHelperId String?
  assignedHelperId String?
  leadScore        Int
  leadTemperature  LeadTemperature
  lifecycleStage   LeadLifecycleStage @default(LEAD)
  whatsappClicked  Boolean            @default(false)
  status           LeadStatus         @default(NEW)
  paymentStatus    PaymentStatus      @default(UNPAID)
  paymentProvider  String?
  paymentAmount    Int?
  paymentCurrency  String?            @default("MYR")
  paymentLinkUrl   String?
  paymentLinkRef   String?
  paymentRef       String?
  paidAt           DateTime?
  releaseReadyAt   DateTime?
  releasedAt       DateTime?
  releaseRef       String?
  paymentRequestedAt DateTime?
  refundedAt       DateTime?
  dealClosed       Boolean            @default(false)
  notes            String             @default("")
  dealValue        Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  selectedHelper   Helper?            @relation("SelectedHelper", fields: [selectedHelperId], references: [id], onDelete: SetNull)
  assignedHelper   Helper?            @relation("AssignedHelper", fields: [assignedHelperId], references: [id], onDelete: SetNull)
  invites          LeadInvite[]

  @@index([status, createdAt])
  @@index([category, taskType])
}

model LeadInvite {
  id          String          @id @default(cuid())
  leadId       String
  helperId     String
  responseToken String        @unique
  inviteGroup LeadInviteGroup
  round       Int             @default(1)
  status      LeadInviteStatus @default(PENDING)
  deliveryStatus LeadInviteDeliveryStatus @default(PENDING)
  deliveryAttemptedAt DateTime?
  deliveryError String?
  estimatedPrice Int?
  availabilityNote String?
  sentAt      DateTime        @default(now())
  respondedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lead        Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  helper      Helper          @relation(fields: [helperId], references: [id], onDelete: Cascade)

  @@unique([leadId, helperId])
  @@index([leadId, inviteGroup, sentAt])
  @@index([helperId, status, sentAt])
}

model LeadDraft {
  id          String         @id @default(cuid())
  userId      String?
  category    HelperCategory
  taskType    LeadTaskType
  urgency     LeadUrgency
  deadline    DateTime
  budget      Int?
  description String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model EventLog {
  id        String   @id @default(cuid())
  eventType String
  helperId  String?
  draftId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([helperId, createdAt])
  @@index([draftId, createdAt])
}
